PORT=5000

# Postgres connection (use Supabase, Railway, or local Postgres with pgvector extension enabled)
DATABASE_URL=postgresql://user:password@localhost:5432/doc_qa_rag

# LLM provider - use either OpenAI or Anthropic
OPENAI_API_KEY=sk-xxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Embedding + chat model names
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Upload limits
MAX_FILE_SIZE_MB=10
