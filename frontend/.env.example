# Copy to .env.local and fill in.

# URL of the backend API (local dev or your deployed Render URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Auth (Project Settings -> API). Leave blank to run in local dev-bypass
# mode (no login screen; backend must have AUTH_ENABLED=false).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
