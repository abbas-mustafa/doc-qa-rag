# Server
PORT=8000
CORS_ORIGINS=http://localhost:3000

# Postgres (Supabase session pooler, IPv4-compatible)
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres

# Gemini (https://aistudio.google.com/apikey)
# Free-tier request quotas are per project *per model*, and small: 20 requests/day
# on gemini-2.5-flash and gemini-3.5-flash, none at all on the 2.0 line. Answering,
# ingestion, and rewriting therefore all share one model's bucket — not by choice;
# every model with a separate bucket is either dead or slow enough to dominate the
# latency of the thing it's meant to protect. One document can spend 70 vision
# requests, so on the free tier a single upload can starve answering until the
# quota resets. Enable billing for anything public.
GEMINI_API_KEY=AIzaSyxxxxxxxx
EMBEDDING_MODEL=gemini-embedding-001
CHAT_MODEL=gemini-3.1-flash-lite
VISION_MODEL=gemini-3.1-flash-lite
# Defaults to CHAT_MODEL's value. Worth splitting only on a paid bucket.
# CONDENSE_MODEL=gemini-3.1-flash-lite

# Uploads
MAX_FILE_SIZE_MB=100

# Auth (Supabase). Set AUTH_ENABLED=true in production.
AUTH_ENABLED=false
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_URL=
